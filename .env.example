# Example .env for Excel theme customization
# Copy this file to `.env` at project root and adjust values as needed.

# General Excel theme (default)
EXCEL_HEADER_BG=#2F4F4F
EXCEL_HEADER_FG=#FFFFFF
EXCEL_ROW_EVEN=#FFFFFF
EXCEL_ROW_ODD=#F6F6F6
EXCEL_TEAM_FILL_COLOR=#EDEDED
EXCEL_DATE_FONT_TRUE=#000000
EXCEL_DATE_FONT_FALSE=#666666
EXCEL_SUMMARY_BG=#FFD966
EXCEL_SUMMARY_FG=#000000

# Flags (true/false)
EXCEL_DISABLE_TEAM_ZEBRA=false
EXCEL_DISABLE_DATE_ZEBRA=false

# Theme specifically for Média Geral (all-records aggregated)
# Prefix: EXCEL_MEDIAS_GERAL_
EXCEL_MEDIAS_GERAL_HEADER_BG=#1F618D
EXCEL_MEDIAS_GERAL_HEADER_FG=#FFFFFF
EXCEL_MEDIAS_GERAL_ROW_EVEN=#FFFFFF
EXCEL_MEDIAS_GERAL_ROW_ODD=#F0F8FF
EXCEL_MEDIAS_GERAL_TEAM_FILL_COLOR=#DDEBF7
EXCEL_MEDIAS_GERAL_DATE_FONT_TRUE=#000000
EXCEL_MEDIAS_GERAL_DATE_FONT_FALSE=#777777
EXCEL_MEDIAS_GERAL_SUMMARY_BG=#FFB3B3
EXCEL_MEDIAS_GERAL_SUMMARY_FG=#000000
EXCEL_MEDIAS_GERAL_DISABLE_TEAM_ZEBRA=false
EXCEL_MEDIAS_GERAL_DISABLE_DATE_ZEBRA=false

# (Optional) Per-type medias themes kept for backward compatibility
EXCEL_MEDIAS_PRODUTIVAS_HEADER_BG=#2E7D32
EXCEL_MEDIAS_IMPRODUTIVAS_HEADER_BG=#B71C1C

# Output column order (comma separated, optional)
#OUTPUT_COLUMNS_ORDER=Equipe,Data Referência,TempPrep,TempPrepJornada,TempExe,TempDesl,Utilizacao,HT_Faltante

# End of example
